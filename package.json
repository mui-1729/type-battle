{
  "name": "type-battle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "NEXT_PUBLIC_CLOUDFLARE_REALTIME_URL=ws://127.0.0.1:8787 npm run build && playwright test",
    "build": "turbo build",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
